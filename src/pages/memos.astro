---
import { Icon } from "astro-icon/components"
import { memosConfig, siteConfig } from "@/config"
import I18nKey from "@/i18n/i18nKey"
import { i18n } from "@/i18n/translation"
import MainGridLayout from "@/layouts/MainGridLayout.astro"
import type { Memo, MemosApiResponse } from "@/types/memos"

if (!siteConfig.pages.memos) {
	return Astro.redirect("/404/")
}

const title = i18n(I18nKey.memos)
const description = i18n(I18nKey.memosSubtitle)

const MAX_MEMOS = 35

// 构建时抓取 memos
let memos: Memo[] = []
let fetchError = false

try {
	const headers: Record<string, string> = { Accept: "application/json" }
	if (memosConfig.accessToken) {
		headers["Authorization"] = `Bearer ${memosConfig.accessToken}`
	}

	const resp = await fetch(
		`${memosConfig.apiUrl}/api/v1/memos?pageSize=${MAX_MEMOS}`,
		{ headers },
	)

	if (resp.ok) {
		const data: MemosApiResponse = await resp.json()
		memos = (data.memos || []).filter(
			(m) => m.visibility === "PUBLIC",
		).slice(0, MAX_MEMOS)
	} else {
		console.warn(`[Memos] API 请求失败: ${resp.status}`)
		fetchError = true
	}
} catch (e) {
	console.warn("[Memos] 无法连接 API:", e)
	fetchError = true
}

// 简易 markdown 渲染（memo 短内容适用）
function renderMarkdown(content: string): string {
	let html = content
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;")

	// fenced code blocks
	html = html.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre class="code-block"><code>$2</code></pre>')
	// inline code
	html = html.replace(/`([^`]+)`/g, "<code>$1</code>")
	// bold
	html = html.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
	// italic
	html = html.replace(/\*(.*?)\*/g, "<em>$1</em>")
	// strikethrough
	html = html.replace(/~~(.*?)~~/g, "<del>$1</del>")
	// links
	html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer" class="link">$1</a>')
	// images
	html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" loading="lazy" class="rounded-lg max-w-full" />')
	// blockquote
	html = html.replace(/^&gt;\s?(.+)$/gm, '<blockquote class="border-l-2 border-(--primary) pl-3 text-neutral-600 dark:text-neutral-400">$1</blockquote>')
	// headings
	html = html.replace(/^#### (.+)$/gm, '<h4 class="text-base font-bold mt-3 mb-1">$1</h4>')
	html = html.replace(/^### (.+)$/gm, '<h3 class="text-lg font-bold mt-3 mb-1">$1</h3>')
	html = html.replace(/^## (.+)$/gm, '<h2 class="text-xl font-bold mt-3 mb-1">$1</h2>')
	html = html.replace(/^# (.+)$/gm, '<h1 class="text-2xl font-bold mt-3 mb-1">$1</h1>')
	// unordered list
	html = html.replace(/^[-*+]\s+(.+)$/gm, "<li>$1</li>")
	html = html.replace(/(<li>.*<\/li>\n?)+/g, "<ul>$&</ul>")
	// horizontal rule
	html = html.replace(/^---+$/gm, '<hr class="border-(--line-divider) my-2" />')
	// line breaks
	html = html.replace(/\n/g, "<br/>")
	// cleanup br after block elements
	html = html.replace(/<\/(h[1-4]|blockquote|pre|ul|li)><br\/>/g, "</$1>")
	html = html.replace(/<br\/><(h[1-4]|blockquote|pre|ul)/g, "<$1")

	return html
}

function formatTime(iso: string): string {
	try {
		const locale = (siteConfig.lang || "zh_CN").replace("_", "-")
		return new Intl.DateTimeFormat(locale, {
			year: "numeric",
			month: "long",
			day: "numeric",
			hour: "2-digit",
			minute: "2-digit",
		}).format(new Date(iso))
	} catch {
		return iso
	}
}

// 构建附件下载 URL
// Memos 的文件访问模式: /file/{name}/{filename}
// 例如: /file/attachments/5c90a5db8929459da21e01/photo.jpg
function getAttachmentUrl(att: { name: string; filename: string; externalLink?: string }): string {
	if (att.externalLink) return att.externalLink
	return `${memosConfig.apiUrl}/file/${att.name}/${encodeURIComponent(att.filename)}`
}
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题 -->
      <div class="mb-4">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
            <Icon name="material-symbols:edit-note" is:inline class="text-[1.5rem]" />
          </div>
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </div>
        </div>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">
          {description}
        </p>
      </div>

      <!-- Memo 列表 -->
      {memos.length > 0 ? (
        <div class="flex flex-col">
          {memos.map((memo, index) => {
            const images = memo.attachments?.filter((a) => a.type?.startsWith("image/")) || []
            const files = memo.attachments?.filter((a) => !a.type?.startsWith("image/")) || []
            return (
              <div
                class="py-5 border-b border-dashed border-(--line-divider) last:border-b-0 first:pt-0 last:pb-0"
                style={`animation-delay: calc(var(--content-delay) + ${index * 50}ms)`}
              >
                <div class="text-xs text-neutral-500 dark:text-neutral-400 mb-2">
                  {formatTime(memo.createTime)}
                </div>
                <div
                  class="custom-md text-base leading-relaxed text-neutral-800 dark:text-neutral-200"
                  set:html={renderMarkdown(memo.content || "")}
                />
                {images.length > 0 && (
                  <div class="moment-images grid grid-cols-2 md:grid-cols-3 gap-2 mt-3">
                    {images.map((img) => (
                      <img
                        src={getAttachmentUrl(img)}
                        alt={img.filename || ""}
                        loading="lazy"
                        class="rounded-lg w-full h-32 object-cover cursor-zoom-in hover:opacity-80 transition-opacity"
                      />
                    ))}
                  </div>
                )}
                {files.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-2">
                    {files.map((f) => (
                      <a
                        href={getAttachmentUrl(f)}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="link text-xs"
                      >
                        {f.filename || f.name}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            )
          })}
        </div>
      ) : (
        <div class="py-10 text-center">
          {fetchError ? (
            <p class="text-red-500">{i18n(I18nKey.memosError)}</p>
          ) : (
            <>
              <p class="text-neutral-500 dark:text-neutral-400">{i18n(I18nKey.memosEmpty)}</p>
              <p class="text-sm text-neutral-400 dark:text-neutral-500 mt-1">{i18n(I18nKey.memosEmptyDescription)}</p>
            </>
          )}
        </div>
      )}
    </div>
  </div>
</MainGridLayout>
