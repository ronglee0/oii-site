---
import { Icon } from "astro-icon/components"
import { Marked } from "marked"
import { memosConfig, siteConfig } from "@/config"
import I18nKey from "@/i18n/i18nKey"
import { i18n } from "@/i18n/translation"
import MainGridLayout from "@/layouts/MainGridLayout.astro"
import type { Memo, MemosApiResponse } from "@/types/memos"

if (!siteConfig.pages.memos) {
	return Astro.redirect("/404/")
}

const title = i18n(I18nKey.memos)
const description = i18n(I18nKey.memosSubtitle)

const MAX_MEMOS = 35

// 构建时抓取 memos
let memos: Memo[] = []
let fetchError = false

try {
	const headers: Record<string, string> = { Accept: "application/json" }
	if (memosConfig.accessToken) {
		headers["Authorization"] = `Bearer ${memosConfig.accessToken}`
	}

	const resp = await fetch(
		`${memosConfig.apiUrl}/api/v1/memos?pageSize=${MAX_MEMOS}`,
		{ headers },
	)

	if (resp.ok) {
		const data: MemosApiResponse = await resp.json()
		memos = (data.memos || []).filter(
			(m) => m.visibility === "PUBLIC",
		).slice(0, MAX_MEMOS)
	} else {
		console.warn(`[Memos] API 请求失败: ${resp.status}`)
		fetchError = true
	}
} catch (e) {
	console.warn("[Memos] 无法连接 API:", e)
	fetchError = true
}

// markdown 渲染
const marked = new Marked()

function renderMarkdown(content: string): string {
	return marked.parse(content, { async: false }) as string
}

function formatTime(iso: string): string {
	try {
		const locale = (siteConfig.lang || "zh_CN").replace("_", "-")
		return new Intl.DateTimeFormat(locale, {
			year: "numeric",
			month: "long",
			day: "numeric",
			hour: "2-digit",
			minute: "2-digit",
		}).format(new Date(iso))
	} catch {
		return iso
	}
}

// 构建附件下载 URL
// Memos 的文件访问模式: /file/{name}/{filename}
// 例如: /file/attachments/5c90a5db8929459da21e01/photo.jpg
function getAttachmentUrl(att: { name: string; filename: string; externalLink?: string }): string {
	if (att.externalLink) return att.externalLink
	const base = `${memosConfig.apiUrl}/file/${att.name}/${encodeURIComponent(att.filename)}`
	const token = memosConfig.accessToken
	return token ? `${base}?token=${token}` : base
}
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题 -->
      <div class="mb-4">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
            <Icon name="material-symbols:edit-note" class="text-[1.5rem]" />
          </div>
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </div>
        </div>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">
          {description}
        </p>
      </div>

      <!-- Memo 列表 -->
      {memos.length > 0 ? (
        <div class="flex flex-col">
          {memos.map((memo, index) => {
            const images = memo.attachments?.filter((a) => a.type?.startsWith("image/")) || []
            const files = memo.attachments?.filter((a) => !a.type?.startsWith("image/")) || []
            return (
              <div
                class="py-5 border-b border-dashed border-(--line-divider) last:border-b-0 first:pt-0 last:pb-0"
                style={`animation-delay: calc(var(--content-delay) + ${index * 50}ms)`}
              >
                <div class="text-xs text-neutral-500 dark:text-neutral-400 mb-2">
                  {formatTime(memo.createTime)}
                </div>
                <div
                  class="custom-md text-sm leading-relaxed text-neutral-800 dark:text-neutral-200"
                  set:html={renderMarkdown(memo.content || "")}
                />
                {images.length > 0 && (
                  <div class="grid grid-cols-2 md:grid-cols-3 gap-2 mt-3">
                    {images.map((img) => (
                      <a href={getAttachmentUrl(img)} target="_blank" rel="noopener noreferrer">
                        <img
                          src={getAttachmentUrl(img)}
                          alt={img.filename || ""}
                          loading="lazy"
                          class="rounded-lg w-full h-32 object-cover hover:opacity-80 transition-opacity"
                        />
                      </a>
                    ))}
                  </div>
                )}
                {files.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-2">
                    {files.map((f) => (
                      <a
                        href={getAttachmentUrl(f)}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="link text-xs"
                      >
                        {f.filename || f.name}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            )
          })}
        </div>
      ) : (
        <div class="py-10 text-center">
          {fetchError ? (
            <p class="text-red-500">{i18n(I18nKey.memosError)}</p>
          ) : (
            <>
              <p class="text-neutral-500 dark:text-neutral-400">{i18n(I18nKey.memosEmpty)}</p>
              <p class="text-sm text-neutral-400 dark:text-neutral-500 mt-1">{i18n(I18nKey.memosEmptyDescription)}</p>
            </>
          )}
        </div>
      )}
    </div>
  </div>
</MainGridLayout>
